{
  "name": "eutgpt-launcher",
  "version": "1.0.2",
  "description": "EUT-GPT Launcher — Desktop UI for EUT-GPT AI",
  "author": "EUT-GPT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node -e \"const p=require('os').platform();require('child_process').execSync('npx electron-builder --'+(p==='win32'?'win nsis':p==='darwin'?'mac dmg':'linux AppImage'),{stdio:'inherit'})\""
  },
  "build": {
    "appId": "ai.eutgpt.launcher",
    "productName": "EUT-GPT Launcher",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "win": {
      "extraResources": [
        {
          "from": "../dist",
          "to": "bin",
          "filter": ["EUT-GPT-CLI-*"]
        }
      ],
      "target": [
        "portable"
      ],
      "icon": "icon.png",
      "artifactName": "EUT-GPT-Launcher-${version}-${arch}-Win.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "runAfterFinish": true
    },
    "mac": {
      "extraResources": [
        {
          "from": "../dist",
          "to": "bin",
          "filter": ["EUT-GPT-CLI-*"]
        }
      ],
      "singleArchFiles": "bin/EUT-GPT-CLI-*",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "icon": "icon.png",
      "artifactName": "EUT-GPT-Launcher-${version}-universal-Mac.${ext}",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "extraResources": [
        {
          "from": "../dist",
          "to": "bin",
          "filter": ["EUT-GPT-CLI-*"]
        }
      ],
      "target": [
        "AppImage"
      ],
      "icon": "icon.png",
      "artifactName": "EUT-GPT-Launcher-${version}-${arch}-Linux.${ext}",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
